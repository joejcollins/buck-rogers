{
	"name": "Literate programming on buck-rogers",
	"image": "ghcr.io/joejcollins/buck-rogers:latest",
	"customizations": {
		"vscode": {
			"extensions": [
				"aaron-bond.better-comments",
				"james-yu.latex-workshop",
				"ms-toolsai.jupyter",
				"ms-python.python",
				"shardulm94.trailing-spaces",
				"tamasfe.even-better-tom",
				"streetsidesoftware.code-spell-checker",
				"sourcery.sourcery"
			],
			"settings": {
				"editor.rulers": [
					80
				],
				"files.exclude": {
					"**/__pycache__": true,
					"**/*.aux": true,
					"**/*.nav": true,
					"**/.pytest_cache": true,
					"**/.ruff_cache": true,
					"**/*.egg-info": true,
					"**/*.pyc": true,
					"**/data/**": true
				},
				"files.watcherExclude": {
					"**/__pycache__": true,
					"**/*.aux": true,
					"**/*.nav": true,
					"**/.pytest_cache": true,
					"**/.ruff_cache": true,
					"**/*.egg-info": true,
					"**/*.pyc": true,
					"**/.venv/**": true,
					"**/data/**": true
				},
				"search.exclude": {
					"**/__pycache__": true,
					"**/*.aux": true,
					"**/*.nav": true,
					"**/.pytest_cache": true,
					"**/.ruff_cache": true,
					"**/*.egg-info": true,
					"**/*.pyc": true,
					"**/.venv/**": true,
					"**/data/**": true
				},
				"files.eol": "\n",
				"editor.formatOnSave": true,
				"files.associations": {
					"*.tex": "latex"
				},
				"latex-workshop.view.pdf.viewer": "tab",
				"latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
				"latex-workshop.synctex.afterBuild.enabled": true,
				"latex-workshop.latex.autoClean.run": "onBuilt",
				"latex-workshop.latex.clean.subfolder.enabled": true,
				"latex-workshop.linting.chktex.enabled": true,
				"latex-workshop.linting.chktex.exec.path": "/usr/local/bin/chktex",
				"latex-workshop.formatting.latex": "tex-fmt",
			}
		}
	},
	"postCreateCommand": ". ./.devcontainer/post-create.sh | tee /tmp/post-create-log.txt"
}